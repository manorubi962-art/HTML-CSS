<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculator</title>
    <a href="https://www.flaticon.com/free-icons/calculate" title="calculate icons"></a> 
    <style>
        *{
            margin: 0px;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body{
            width: 100%;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background:black;
        }
        .calculator{
              padding: 20px;
              box-sizing: border-box;
              box-shadow: 0 3px 15px rgba(226, 225, 225, 0.5);
              border: 1px solid rgb(2, 2, 2);
              border-radius: 5px;
              background: rgb(41, 40, 40);
        }
        .head{
            font-size: 18px;
            color: rgb(230, 222, 222);
            padding: 0;
            margin: 0;
        }
        input{
         width: 320px;
         padding: 24px;
         border: 1px solid black;
         margin: 10px;
         background: transparent;
         box-shadow: 0 3px 15px rgba(5, 5, 5, 0.7);
         text-align: right;
         font-size: 40px;
         cursor: pointer;
         color: aliceblue;

        }
        input::placeholder{
            color: rgb(240, 236, 236);
        }
        button{
            padding: 20px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            margin: 10px;
            border: none;
            color: aliceblue;
            font-size: 20px;
            background-color:rgb(75, 68, 68);
            font-size: 20px;
            box-shadow: -8 -8 15px rgba(15, 15, 15, 0.7);
        }
        .equal{
            background-color: orange;
        }
        .operator{
            color: rgb(36, 230, 36);
            font-size: 16px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="calculator">
    <div class="head">
        <span class="icon">☰</span>
        <span class="text">Standard</span>
        
    </div>
        
        <input type="text" placeholder="0" id="inputbox">
        <div>
        <button class="operator">AC</button>
        <button class="operator">DEL</button>
        <button class="operator">%</button>
        <button class="operator">/</button>
          </div>
           <div>
          <button>7</button>
          <button>8</button>
          <button>9</button>
          <button class="operator">*</button>
           </div>
           <div>
          <button>4</button>
          <button>5</button>
          <button>6</button>
          <button class="operator">-</button>
           </div>
           <div>
          <button>3</button>
          <button>2</button>
          <button>1</button>
          <button class="operator">+</button>
           </div>
           <div>
            <button>00</button>
            <button>0</button>
            <button>.</button>
            <button class="equal">=</button>
           </div>
    </div>
    <script src="script.js">
      
let input = document.getElementById('inputbox');
let buttons = document.querySelectorAll('button');


let string = "";


buttons.forEach(button => {
    button.addEventListener('click', (e) => {
        let buttonText = e.target.innerHTML;

      
        if (buttonText == '=') {
            try {
               
                string = eval(string);
                input.value = string;
            } catch (error) {
             
                input.value = "Error";
                string = "";
            }
        } 
       
        else if (buttonText == 'AC') {
            string = "";
            input.value = "";
        } 
      
        else if (buttonText == 'DEL') {
            string = string.substring(0, string.length - 1);
            input.value = string;
        } 
       
        else {
            string += buttonText;
            input.value = string;
        }
    });
});
    </script>
</body>
</html>
